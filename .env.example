# OpenAI API Configuration
# Copy this file to .env and add your actual API key

# Your OpenAI API key (required for AI analysis)
OPENAI_API_KEY=your-api-key-here

# Optional: Custom API endpoint (defaults to OpenAI)
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Note: Without a valid API key, the application will use fallback mode
# which provides basic text statistics instead of AI-powered insights
